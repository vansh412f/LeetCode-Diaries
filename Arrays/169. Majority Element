
class Solution {
    public int majorityElement(int[] nums) {
        int majority =0;
        for(int i = 0; i< nums.length; i++){
            int current = nums[i];
            int count = 0;
            for( int j = i; j<nums.length; j++){
                if(nums[j] == current){
                    count++;
                }
            }
            if(count > (nums.length/2)){
                majority = current;
            }
        }
        return majority;
    }
}
