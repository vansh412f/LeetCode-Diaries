class Solution {
    public int[] productExceptSelf(int[] nums) {
        int n = nums.length;
        int ans[] = new int[n];
        int pro = 1;
        for(int i : nums) {
            pro *= i;
        }
        
        for(int i = 0; i < n; i++) {
            if(nums[i]==0){
                ans[i] = pro;
            } else{
            ans[i] = pro / nums[i];
            }
        }
        return ans;
    }
}
