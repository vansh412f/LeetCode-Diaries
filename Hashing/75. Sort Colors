class Solution {
    public void sortColors(int[] nums) {
        HashMap<Integer, Integer> map = new HashMap<>();
        map.put(0, 0);
        map.put(1, 0);
        map.put(2, 0);
        for(int num : nums){
            map.put(num, map.get(num) + 1);
        }
        int i =0;
        for(int c=0; c<3; c++){
            int freq = map.get(c);
            for(int j =0; j<freq; j++){
                nums[i] = c;
                i++; map.put(c, map.get(c)-1);
            }
        }
    }
}
