class Solution {
    public int[] findMissingAndRepeatedValues(int[][] grid) {
        int n = grid.length;
        int size = n*n;
        int [] freq = new int[size+1];
        int [] result = new int[2];
        for(int [] row: grid){
            for(int num: row){
                freq[num] ++;
            }
        }
        for(int i=1; i<size+1; i++){
            if(freq[i] == 2){
                result[0] = i;
            }
            if(freq[i] == 0){
                result[1] = i;
            }
        }
        return result;
    }
}
