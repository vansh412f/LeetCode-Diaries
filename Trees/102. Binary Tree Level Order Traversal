/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public List<List<Integer>> levelOrder(TreeNode root) {
        List<List<Integer>> l = new ArrayList<>();
        func(root, 0, l);
        return l;
    }
    public static void func(TreeNode root, int level, List<List<Integer>> l){
        if(root == null){
            return;
        }
        if(l.size() == level){
            List<Integer> li = new ArrayList<>();
            li.add(root.val);
            l.add(li);
        } else{
            l.get(level).add(root.val);
        }
        func(root.left, level +1, l);
        func(root.right, level +1, l);
    }
}
